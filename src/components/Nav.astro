---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isAbout = pathname === '/about' || pathname === '/about/';
const isContact = pathname === '/contact' || pathname === '/contact/';
---

<nav>
  <a href="/" class="nav-brand">
    <img src="/logo.png" alt="RaisingImpact logo" class="nav-logo" />
    <span class="nav-brand-name">RaisingImpact</span>
  </a>

  <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <ul class="nav-links">
    <li><a href="/" class={isHome ? 'active' : ''}>Home</a></li>
    <li><a href="/about" class={isAbout ? 'active' : ''}>About Us</a></li>
    <li><a href="/contact" class={isContact ? 'active' : ''}>Contact Us</a></li>
  </ul>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const links  = document.querySelector('.nav-links') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const open = links.classList.toggle('open');
    toggle.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
  });

  // close menu when a link is clicked
  links?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    })
  );
</script>
