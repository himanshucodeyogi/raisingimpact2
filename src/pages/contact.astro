---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — Raising Impact">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="hero-tag">Raising Impact</div>
    <h1>Guiding Philanthropy With Rigour</h1>
    <div class="gold-bar"></div>
  </section>

  <!-- CONTACT BODY -->
  <div class="contact-section">

    <!-- LEFT: INFO -->
    <div class="contact-info">
      <h2>Get In Touch</h2>
      <div class="gold-bar-sm"></div>
      <p class="note">
        If you would like to learn more about Raising Impact and the work we do, please write to us at
        <a href="mailto:rukmini@raisingimpact.org" class="contact-email-link">rukmini@raisingimpact.org</a>.
      </p>
    </div>

    <!-- RIGHT: FORM -->
    <div class="contact-form">
      <h2 style="font-family:'Playfair Display',serif; font-size:1.5rem; color:var(--navy-dark); margin-bottom:6px;">Send Us a Message</h2>
      <p class="form-note">We usually respond within 2–3 business days.</p>

      <form id="contact-form">
        <div class="form-group">
          <label>Name <span>*</span></label>
          <input type="text" placeholder="Your full name" required />
        </div>
        <div class="form-group">
          <label>Email <span>*</span></label>
          <input type="email" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
          <label>Organisation</label>
          <input type="text" placeholder="Company / foundation (optional)" />
        </div>
        <div class="form-group">
          <label>Subject <span>*</span></label>
          <input type="text" placeholder="What is this about?" required />
        </div>
        <div class="form-group">
          <label>Message <span>*</span></label>
          <textarea placeholder="Tell us how we can help..." required></textarea>
        </div>
        <button type="submit" class="btn-primary">Send Message</button>
        <p class="form-legal">By submitting this form, you agree to be contacted by Raising Impact.</p>
      </form>

      <div id="success-msg" style="display:none; margin-top:24px; padding:18px 20px; background:#e8f5e9; border-left:4px solid #4caf50; border-radius:2px;">
        <p style="color:#2e7d32; font-size:0.95rem; font-weight:500;">Thank you! Your message has been sent. We'll be in touch within 2–3 business days.</p>
      </div>
    </div>

  </div>

</Layout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    (e.target as HTMLFormElement).style.display = 'none';
    const msg = document.getElementById('success-msg');
    if (msg) msg.style.display = 'block';
  });
</script>
