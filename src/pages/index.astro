---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Raising Impact — Guiding Philanthropy With Rigour">

  <!-- HERO -->
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="hero-content">
      <div class="hero-tag">Raising Impact</div>
      <h1>Guiding Philanthropy With Rigour</h1>
      <p class="hero-subtitle">Evidence-led advisory for high-impact giving</p>
      <div class="hero-divider"></div>
      <p class="hero-body">We help philanthropists maximise social impact through rigorous research, cost-effectiveness analysis, and transparent methods.</p>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="pillars">
    <div class="pillars-grid">

      <div class="pillar-card">
        <svg class="pillar-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="6" y="28" width="8" height="10" rx="1" fill="#C09D4B" opacity="0.3"/>
          <rect x="18" y="20" width="8" height="18" rx="1" fill="#C09D4B" opacity="0.5"/>
          <rect x="30" y="12" width="8" height="26" rx="1" fill="#C09D4B"/>
          <path d="M8 16 L18 10 L28 14 L38 6" stroke="#1E3A5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="38" cy="6" r="2.5" fill="#1E3A5A"/>
        </svg>
        <h3>Evidence Led</h3>
        <p>We prioritise data &amp; evidence when unpacking key problems, applying structured frameworks to evaluate problem-severity &amp; existing fund flows.</p>
      </div>

      <div class="pillar-card">
        <svg class="pillar-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="22" r="14" stroke="#C09D4B" stroke-width="2"/>
          <circle cx="22" cy="22" r="7" stroke="#1E3A5A" stroke-width="2"/>
          <path d="M22 8 L22 36" stroke="#C09D4B" stroke-width="1.5" stroke-dasharray="3 3"/>
          <path d="M8 22 L36 22" stroke="#C09D4B" stroke-width="1.5" stroke-dasharray="3 3"/>
          <circle cx="22" cy="22" r="3" fill="#C09D4B"/>
        </svg>
        <h3>Regionally Rooted</h3>
        <p>We blend methodological rigour with deep regional understanding to deliver contextually grounded insights, verified through on-ground partnerships.</p>
      </div>

      <div class="pillar-card">
        <svg class="pillar-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="22" r="14" stroke="#C09D4B" stroke-width="2"/>
          <path d="M22 14 L22 18" stroke="#C09D4B" stroke-width="2" stroke-linecap="round"/>
          <path d="M22 26 L22 30" stroke="#C09D4B" stroke-width="2" stroke-linecap="round"/>
          <path d="M17 19.5 C17 17.5 19 16 22 16.5 C25 17 26 19 24 20.5 C22 22 18 22 18 24.5 C18 26.5 20 28 22 27.5 C24 27 26 25.5 26 23.5" stroke="#1E3A5A" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <h3>Cost-Effective</h3>
        <p>We prioritize interventions that offer the most significant impact per dollar spent, with the potential to scale across regions.</p>
      </div>

    </div>
  </section>

</Layout>
