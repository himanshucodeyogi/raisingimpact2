---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Raising Impact" active="home">
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline preload="auto">
      <source src="/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <h1>Raising Impact</h1>
      <p class="tagline">Guiding Philanthropy With Rigour</p>
      <hr class="hero-divider" />
      <h2>Evidence-led advisory for high-impact giving</h2>
      <p class="lead">We help philanthropists maximise social impact through rigorous research, cost-effectiveness analysis, and transparent methods.</p>
    </div>
  </section>

  <section class="pillars">
    <div class="section-container">
      <div class="pillar-grid">
        <div class="pillar-card">
          <h3>Analytically rigorous</h3>
          <p>Leverage evidence to unpack key development problems</p>
        </div>
        <div class="pillar-card">
          <h3>Regionally rooted</h3>
          <p>Anchor analysis in rigorous methods and regional insight</p>
        </div>
        <div class="pillar-card">
          <h3>Cost-effective solutions</h3>
          <p>Ensure every dollar invested delivers maximum outcomes</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
