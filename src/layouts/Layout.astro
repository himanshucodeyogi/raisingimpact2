---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Raising Impact is an evidence-led philanthropy advisory organisation helping donors maximise social impact through rigorous research, cost-effectiveness analysis, and systematic methods.',
  image = '/logo.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Raising Impact" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Raising Impact",
    "url": "https://raisingimpact.org",
    "logo": "https://raisingimpact.org/logo.png",
    "description": "Evidence-led philanthropy advisory organisation helping donors maximise social impact.",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "info@raisingimpact.org",
      "contactType": "customer service"
    }
  })} />

  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <Nav />
  <slot />
  <Footer />

  <button id="scroll-top" aria-label="Back to top" title="Back to top">
    ↑
  </button>
</body>

<script>
  const btn = document.getElementById('scroll-top') as HTMLButtonElement;

  window.addEventListener('scroll', () => {
    btn.classList.toggle('visible', window.scrollY > 300);
  });

  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
</html>
